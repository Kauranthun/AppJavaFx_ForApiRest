<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rodaxsoft.controllers.TaskController" prefHeight="600.0" prefWidth="1000.0">

    <top>
        <fx:include source="Menu.fxml"/>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Task manager" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TableView fx:id="taskTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="100" />
                    <TableColumn fx:id="colTitle" text="Title" prefWidth="150" />
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="300" />
                    <TableColumn fx:id="colStatus" text="State" prefWidth="100" />
                    <TableColumn fx:id="colDue" text="Due" prefWidth="200" />
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Refresh" onAction="#handleRefresh" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: gray;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>